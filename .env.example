# Phase 1: no external APIs — all defaults work out of the box
DATABASE_URL=sqlite:///./data/lynk.db
CORS_ORIGINS=http://localhost:5173

# Phase 2: Outreach core
# Claude API — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL_DEFAULT=claude-haiku-4-5-20251001
CLAUDE_MODEL_HIGH_PRIORITY=claude-sonnet-4-6

# Gmail SMTP — generate an app password at https://myaccount.google.com/apppasswords
# (requires 2FA enabled on the account)
SENDING_ENABLED=false
GMAIL_USER=f20221215@goa.bits-pilani.ac.in
GMAIL_APP_PASSWORD=

# Tracking pixel base URL
# Must be a publicly reachable URL when SENDING_ENABLED=true (e.g. ngrok tunnel)
# Use https://ngrok.com/download for local dev, Fly.io for prod
TRACKING_BASE_URL=http://localhost:8000

FOLLOW_UP_SCHEDULER_ENABLED=true
